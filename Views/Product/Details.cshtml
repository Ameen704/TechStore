@model TechStore.Models.Product
@{
    ViewData["Title"] = "Product Details";
}
<h2>@Model.Name</h2>
<div class="row">
    <div class="col-md-4">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/products/no-image.png" : Model.ImageUrl)" class="img-fluid rounded" />
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("0.00")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
